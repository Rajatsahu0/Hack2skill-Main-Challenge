PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/travel_engine
JWT_SECRET=your_jwt_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# AI Provider (pick ONE - priority: Groq > Gemini > xAI > OpenAI)
GROQ_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# Production: Set this to your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app
